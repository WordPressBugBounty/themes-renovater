    "styles": {
        "spacing": {
            "blockGap": "1.2rem"
        },
        "blocks": {
            "core/post-content": {
                "spacing": {
                    "margin": {
                        "top": "0px"
                    }
                }
            }
        },
        "elements": {
            "heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--roboto)"
                },
                "color": {
                    "text": "var(--wp--preset--color--renovater-primary)"
                }
            },
            "link": {
                "typography": {
                    "textDecoration": "underline",
                    "fontFamily": "var(--wp--preset--font-family--roboto)"
                },
                "color": {
                    "text": "var:preset|color|renovater-accent"
                }
            },
            "button": {
                "color": {
                    "background": "var(--wp--preset--color--renovater-accent)",
                    "text": "var(--wp--preset--color--renovater-primary)"
                }
            }
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--ibm-plex-sans)"
        },
        "color": {
            "text": "var(--wp--preset--color--renovater-body-text)"
        }
    },
    "templateParts": [
        {
            "area": "header",
            "name": "header"
        },
        {
            "area": "footer",
            "name": "footer"
        }
    ],
    "version": 2
}